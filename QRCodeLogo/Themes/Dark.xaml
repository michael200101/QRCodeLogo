<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette. Keys are shared with Light.xaml so the two can be swapped at runtime. -->
    <SolidColorBrush x:Key="WindowBg"  Color="#FF17171B"/>
    <SolidColorBrush x:Key="SurfaceBg" Color="#FF222229"/>
    <SolidColorBrush x:Key="InputBg"   Color="#FF2D2D36"/>
    <SolidColorBrush x:Key="BorderClr" Color="#FF3A3A44"/>
    <SolidColorBrush x:Key="TextClr"   Color="#FFECECF1"/>
    <SolidColorBrush x:Key="MutedClr"  Color="#FF9A9AA7"/>
    <SolidColorBrush x:Key="Accent"      Color="#FF5B8DEF"/>
    <SolidColorBrush x:Key="AccentHover" Color="#FF7BA4F3"/>
    <SolidColorBrush x:Key="OnAccent"    Color="#FFFFFFFF"/>

    <!-- The QR always sits on a light card so its black modules keep contrast in either theme. -->
    <SolidColorBrush x:Key="QrCardBg" Color="#FFFFFFFF"/>

</ResourceDictionary>
