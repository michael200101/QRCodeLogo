<Window x:Class="QRCodeLogo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QRCodeLogo"
        mc:Ignorable="d"
        Title="QR-Code Generator" Height="820" Width="1080" MinHeight="640" MinWidth="900"
        Background="{DynamicResource WindowBg}"
        TextOptions.TextFormattingMode="Ideal">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="QR-Code Generator" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Live-Vorschau – Änderungen werden sofort angezeigt" Style="{StaticResource Muted}"/>
            </StackPanel>
            <Button x:Name="ThemeToggleButton" Grid.Column="1" Content="☀  Hell"
                    VerticalAlignment="Center" Click="ToggleTheme_Click"/>
        </Grid>

        <!-- ============ Content ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Left: settings -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel>

                    <!-- Type -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Typ" Style="{StaticResource SectionHeader}"/>
                            <RadioButton GroupName="1" Content="Normal" Checked="Normal_Checked" IsChecked="True"/>
                            <RadioButton GroupName="1" Content="Contact" Checked="Normal_Checked"/>
                            <RadioButton GroupName="1" Content="Wi-Fi" Checked="Normal_Checked"/>
                        </StackPanel>
                    </Border>

                    <!-- Content -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Inhalt" Style="{StaticResource SectionHeader}"/>

                            <TextBox x:Name="Input" AcceptsReturn="True" TextWrapping="Wrap"
                                     MaxLength="1273" MinHeight="120" VerticalContentAlignment="Top"
                                     FontSize="14" TextChanged="OnInputChanged"/>

                            <StackPanel x:Name="Contact" Visibility="Collapsed">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Vorname"/>
                                    <TextBox Grid.Column="1" x:Name="TextVorname" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Nachname"/>
                                    <TextBox Grid.Column="1" x:Name="TextNachname" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Telefonnummer Mobil"/>
                                    <TextBox Grid.Column="1" x:Name="TextTelefonnummer" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Telefonnummer Festnetz"/>
                                    <TextBox Grid.Column="1" x:Name="TextTelefonnummerFest" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="E-Mail"/>
                                    <TextBox Grid.Column="1" x:Name="TextEMail" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Firma"/>
                                    <TextBox Grid.Column="1" x:Name="TextFirma" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Titel"/>
                                    <TextBox Grid.Column="1" x:Name="TextTitel" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Straße"/>
                                    <TextBox Grid.Column="1" x:Name="TextStraße" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Stadt"/>
                                    <TextBox Grid.Column="1" x:Name="TextStadt" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="PLZ"/>
                                    <TextBox Grid.Column="1" x:Name="TextPLZ" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Land"/>
                                    <TextBox Grid.Column="1" x:Name="TextLand" TextChanged="OnInputChanged"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="Wifi" Visibility="Collapsed">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Sicherheit"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <RadioButton GroupName="2" Content="WPA/WPA2/WPA3" Checked="RadioButton_Checked" Margin="0,4,16,4"/>
                                        <RadioButton GroupName="2" Content="WEP" Checked="RadioButton_Checked" Margin="0,4,16,4"/>
                                        <RadioButton GroupName="2" Content="None" Checked="RadioButton_Checked" Margin="0,4"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="SSID"/>
                                    <TextBox Grid.Column="1" x:Name="SSID" TextChanged="OnInputChanged"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="135"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <Label Content="Passwort"/>
                                    <TextBox Grid.Column="1" x:Name="Passwort" TextChanged="OnInputChanged"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Options -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Optionen" Style="{StaticResource SectionHeader}"/>
                            <CheckBox x:Name="LogoCheckBox" Content="Logo verwenden" Checked="CheckBox_Checked_1" Unchecked="CheckBox_Checked_1"/>
                            <CheckBox Content="Hintergrund transparent" Checked="CheckBox_Checked" Unchecked="CheckBox_Checked"/>

                            <TextBlock Text="Logo-Größe" Margin="0,12,0,4"/>
                            <Slider x:Name="LogoSizeSlider" Minimum="5" Maximum="60" Value="20"
                                    TickFrequency="5" ValueChanged="LogoSizeSlider_ValueChanged"/>
                            <TextBlock x:Name="LogoSizeLabel" Text="20 % der QR-Breite" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Folder actions -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Logo-Ordner öffnen" Click="Button_Click_1"/>
                        <Button Grid.Column="2" Content="QR-Ordner öffnen" Click="Button_Click_2"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Right: preview + save + gallery -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- QR preview on a light card for guaranteed contrast -->
                <Border Background="{DynamicResource QrCardBg}" CornerRadius="16" Padding="20"
                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.35" Color="#FF000000"/>
                    </Border.Effect>
                    <Image x:Name="Output" Source="/QR/qr.png" Stretch="Uniform"/>
                </Border>

                <Button Grid.Row="1" Content="Als PNG speichern" Style="{StaticResource PrimaryButton}"
                        Margin="0,14,0,0" Click="Button_Click"/>

                <!-- Logo gallery -->
                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Logo auswählen" Style="{StaticResource SectionHeader}" Margin="0"/>
                            <Button Grid.Column="1" Content="Aktualisieren" Padding="10,5" Click="RefreshLogos_Click"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="170">
                            <ItemsControl x:Name="LogoGallery">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="Logo_Click" Margin="4" Padding="0"
                                                BorderThickness="0" Background="Transparent" Cursor="Hand"
                                                ToolTip="{Binding Name}">
                                            <Border CornerRadius="8" BorderThickness="3" Padding="3"
                                                    Background="{DynamicResource InputBg}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Image Source="{Binding Thumbnail}" Width="64" Height="64" Stretch="Uniform"/>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
